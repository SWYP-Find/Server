@startuml
hide circle
hide methods
skinparam linetype ortho

entity "USERS\n사용자" as users {
  * id : uuid <<PK>>
}

entity "NOTICES\n전체 공지" as notices {
  * id : uuid <<PK>>
  --
  title : string
  body : text
  notice_type : string
  is_pinned : boolean
  starts_at : datetime
  ends_at : datetime
  created_at : datetime
}

entity "NOTIFICATIONS\n알림 발송 이력" as notifications {
  * id : uuid <<PK>>
  --
  user_id : uuid <<FK>>
  notification_type : string
  title : string
  body : text
  payload_json : text
  status : string
  scheduled_at : datetime
  sent_at : datetime
  failed_at : datetime
  provider_message_id : string
  failure_reason : string
  created_at : datetime
}

users ||--o{ notifications

@enduml
